{
    "name": "digital-lifeboat",
    "version": "1.0.0",
    "description": "ARIA — Offline Disaster Relief Command Centre (Electron)",
    "main": "electron/main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --inspect",
        "dist": "electron-builder"
    },
    "dependencies": {},
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.13.3"
    },
    "build": {
        "appId": "org.digital-lifeboat.aria",
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                "dmg",
                "zip"
            ]
        },
        "files": [
            "index.html",
            "app.js",
            "styles.css",
            "electron/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "../backend",
                "to": "backend"
            }
        ]
    },
    "author": "",
    "license": "MIT"
}